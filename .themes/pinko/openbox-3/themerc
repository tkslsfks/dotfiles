osd.hilight.bg.color: #d4cfbb

osd.unhilight.bg: Flat Solid
osd.unhilight.bg.color: #888888

!! [Border Settings - Keep the outer border dark!]
border.width: 1
border.color: #000000
window.client.padding.width: 0
window.handle.width: 2
padding.width: 1
menu.overlap: 15

!! Font settings
window.active.label.text.font: Sans Bold 9:shadow=y:shadowtint=35:shadowoffset=1
